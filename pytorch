import os
import torch
from torch.utils.data import Dataset, DataLoader


country_files = [
    ("Scottish.txt",    0),
    ("Greek.txt",       1),
    ("Spanish.txt",     2),
    ("Japanese.txt",    3),
    ("Korean.txt",      4),
    ("Polish.txt",      5),
    ("Portuguese.txt", 6),
    ("Russian.txt",     7),
    ("Italian.txt",     8),
    ("Irish.txt",       9),
    ("Arabic.txt",     10),
    ("Vietnamese.txt", 11),
    ("Chinese.txt",    12),
    ("Czech.txt",      13),
    ("Dutch.txt",      14),
    ("English.txt",    15),
    ("French.txt",     16),
    ("German.txt",     17),
]


DATA_FOLDER = "datafile"


all_chars = set()
name_list = []

for filename, _ in country_files:

    file_path = os.path.join(DATA_FOLDER, filename)
    with open(file_path, "r", encoding="utf-8") as f:
        names = [line.strip() for line in f if line.strip()]
        for name in names:
            all_chars.update(name)
            name_list.append((name, filename))


all_chars = sorted(list(all_chars))
char_to_idx = {c: i for i, c in enumerate(all_chars)}
vocab_size = len(all_chars)
num_countries = 18

print(f"Vocabulary size: {vocab_size}")
print(f"Total samples: {len(name_list)}")


class NameOneHotDataset(Dataset):
    def __init__(self, country_files, char_to_idx, num_countries):
        self.data = []
        self.char_to_idx = char_to_idx
        self.num_countries = num_countries
        self.vocab_size = len(char_to_idx)
        self.data_folder = DATA_FOLDER

        for filename, label_idx in country_files:
            file_path = os.path.join(self.data_folder, filename)
            with open(file_path, "r", encoding="utf-8") as f:
                names = [line.strip() for line in f if line.strip()]
            for name in names:
           
                country_vec = torch.zeros(num_countries)
                country_vec[label_idx] = 1.0

              
                name_onehot = []
                for c in name:
                    idx = char_to_idx[c]
                    vec = torch.zeros(self.vocab_size)
                    vec[idx] = 1.0
                    name_onehot.append(vec)
                name_tensor = torch.stack(name_onehot)

                self.data.append((name_tensor, country_vec))

    def __len__(self):
        return len(self.data)

    def __getitem__(self, idx):
        return self.data[idx]


dataset = NameOneHotDataset(country_files, char_to_idx, num_countries)


x, y = dataset[0]

print("Input (name one-hot tensor) shape:", x.shape) 
print("Output (country label vector) shape:", y.shape)   
print("Output vector content:", y)

# DataLoader for training
dataloader = DataLoader(dataset, batch_size=32, shuffle=True)
